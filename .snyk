# Snyk (https://snyk.io) policy file
# ============================================================
# StudyGo — Vulnerability Policy
# Last updated: 2026-04-19
# ============================================================

version: v1.25.0

# ── Ignore rules — each entry includes documented justification ──
ignore:

  # ─── CLOUDINARY < 2.7.0 — GHSA-g4mf-96x5-5m2c ────────────────
  # Severity: HIGH
  # Issue: Arbitrary Argument Injection — unsanitized ampersand in
  #   upload parameters could allow injection of unintended CLI args.
  # Fix: cloudinary@2.9.0 patches this, but it is a BREAKING CHANGE
  #   (v2 SDK has a different API surface — requires refactoring all
  #   upload/delete calls throughout the controllers/Course.js and
  #   controllers/Subsection.js files).
  # Mitigation: Cloudinary parameters in this app originate exclusively
  #   from authenticated instructor uploads — not from public user input.
  #   Exploitability is therefore very low in our threat model.
  # Action: Scheduled for v2 migration in next sprint.
  GHSA-g4mf-96x5-5m2c:
    - '*':
        reason: "Breaking change — cloudinary@2.x migration scheduled. Low exploitability: params come from authenticated users only."
        expires: '2026-07-01T00:00:00.000Z'

  # ─── NODEMAILER <= 8.0.4 — Multiple CVEs ──────────────────────
  # Severity: HIGH
  # Issues:
  #   - GHSA-mm7p-fcc7-pg87 : Email routing to unintended domain
  #   - GHSA-rcmh-qjqh-p98v : addressparser DoS via recursive calls
  #   - GHSA-c7w3-x93f-qmm8 : SMTP command injection via envelope.size
  #   - GHSA-vvjj-xcjg-gr5g : SMTP injection via CRLF in transport name
  # Fix: nodemailer@8.0.5 patches this but is a BREAKING CHANGE
  #   (transport API changes affect mail/ templates and OTP sending).
  # Mitigation: All email inputs (OTP, contact form) are server-generated
  #   or validated before being passed to Nodemailer. The SMTP transport
  #   name is a static string defined in config — not user-controlled.
  #   CRLF injection and envelope.size injection are not reachable.
  # Action: Will upgrade to nodemailer@8+ in next maintenance cycle.
  GHSA-mm7p-fcc7-pg87:
    - '*':
        reason: "Breaking change — nodemailer v8 migration scheduled. Email inputs are server-generated or validated before use."
        expires: '2026-07-01T00:00:00.000Z'
  GHSA-rcmh-qjqh-p98v:
    - '*':
        reason: "addressparser DoS — not exploitable: we do not parse arbitrary user-supplied email strings."
        expires: '2026-07-01T00:00:00.000Z'
  GHSA-c7w3-x93f-qmm8:
    - '*':
        reason: "envelope.size injection — not exploitable: envelope is built from validated, server-controlled data only."
        expires: '2026-07-01T00:00:00.000Z'
  GHSA-vvjj-xcjg-gr5g:
    - '*':
        reason: "Transport name is a static config string — CRLF injection path is not reachable in our setup."
        expires: '2026-07-01T00:00:00.000Z'

  # ─── NODEMON semver / simple-update-notifier ──────────────────
  # Severity: HIGH (transitive, dev-only)
  # Issue: semver < 7.5.2 ReDoS via untrusted version string
  # Fix: Requires nodemon@3.x (breaking changes to watch config)
  # Impact: nodemon is a DEV-ONLY dependency — it is NOT present in
  #   the production Docker image (which uses `node index.js` directly).
  #   No production code path executes nodemon. Risk = zero in prod.
  # Action: Will upgrade nodemon to v3 in dev environment only.
  GHSA-c2qf-rxjj-qqgw:
    - '*':
        reason: "Dev-only dependency (nodemon). Not present in production Docker image. Zero production impact."
        expires: '2026-07-01T00:00:00.000Z'

  # ─── @mapbox/node-pre-gyp → tar path traversal ────────────────
  # Severity: HIGH (transitive)
  # Issue: node-tar path traversal/symlink vulnerabilities
  # Context: tar is a transitive dep of @mapbox/node-pre-gyp, which is
  #   used by bcrypt at install time only (native module compilation).
  #   The tar vulnerability is only exploitable when extracting a
  #   maliciously crafted tarball — which happens at `npm install` time,
  #   not at application runtime.
  # Mitigation: Our CI pipeline always uses a pinned, trusted npm
  #   registry with integrity verification (npm ci). No user-supplied
  #   archives are extracted at runtime.
  # Action: Monitor for @mapbox/node-pre-gyp update that bumps tar.
  GHSA-34x7-hfp2-rc4v:
    - '*':
        reason: "Install-time only (bcrypt native build). Not reachable at runtime. npm ci uses verified registry."
        expires: '2026-07-01T00:00:00.000Z'
  GHSA-8qq5-rm4j-mr97:
    - '*':
        reason: "Install-time only. No user-supplied archives extracted at runtime."
        expires: '2026-07-01T00:00:00.000Z'

# ── Patch rules ──
patch: {}
