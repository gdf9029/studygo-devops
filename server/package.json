{
	"name": "studygo-backend",
	"version": "1.0.0",
	"description": "studygo-backend",
	"main": "index.js",
	"scripts": {
		"start": "node index.js",
		"dev": "nodemon index.js",
		"test": "jest --testPathPattern=tests/ --forceExit --passWithNoTests",
		"test:coverage": "jest --testPathPattern=tests/ --coverage --coverageDirectory=./coverage --coverageReporters=lcov --coverageReporters=text --forceExit --passWithNoTests",
		"test:ci": "jest --testPathPattern=tests/ --coverage --coverageReporters=lcov --coverageReporters=clover --ci --forceExit --passWithNoTests"
	},
	"keywords": [
		"studygo-backend"
	],
	"author": "Saikat Mukherjee",
	"license": "ISC",
	"jest": {
		"testEnvironment": "node",
		"coverageThreshold": {
			"global": {
				"branches": 60,
				"functions": 60,
				"lines": 70,
				"statements": 70
			}
		}
	},
	"dependencies": {
		"bcrypt": "^5.1.0",
		"bcryptjs": "^2.4.3",
		"cloudinary": "^1.36.4",
		"cookie-parser": "^1.4.6",
		"cors": "^2.8.5",
		"crypto-random-string": "^5.0.0",
		"dotenv": "^16.0.3",
		"express": "^4.18.2",
		"express-fileupload": "^1.4.0",
		"jsonwebtoken": "^9.0.0",
		"mongoose": "^7.0.3",
		"node-schedule": "^2.1.1",
		"nodemailer": "^6.9.1",
		"nodemon": "^2.0.22",
		"otp-generator": "^4.0.1",
		"razorpay": "^2.8.6"
	},
	"devDependencies": {
		"@jest/globals": "^29.7.0",
		"jest": "^29.7.0",
		"supertest": "^6.3.4"
	}
}
